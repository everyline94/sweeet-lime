{
  "name": "sweeet-lime",
  "version": "1.0.0",
  "private": true,
  "description": "O design system da lima: tokens, componentes shadcn e catalogo.",
  "exports": {
    ".": "./index.ts",
    "./tokens.css": "./styles/tokens.css",
    "./components/*": "./components/*.tsx",
    "./components/ui/*": "./components/ui/*.tsx",
    "./lib/*": "./lib/*.ts"
  },
  "files": [
    "components",
    "lib",
    "styles",
    "index.ts",
    "registry.json",
    "public/r"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "registry:build": "shadcn build",
    "registry:serve": "npx --yes serve public -l 4000",
    "ui:add": "shadcn add",
    "ui:diff": "sh -c 'shadcn add \"$0\" --diff'"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-themes": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "16.2.10",
    "storybook": "^10.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.1.4"
  }
}
